        if(inside){ctx.lineWidth=BW*2.2;ctx.strokeStyle='rgba(155,100,85,0.35)';ctx.lineCap='round';ctx.beginPath();ctx.moveTo(lx,ly);ctx.lineTo(x,y);ctx.stroke();
          for(var i=0;i<5;i++){ctx.fillStyle='rgba(140,105,95,0.04)';ctx.beginPath();ctx.arc(x+(Math.random()-0.5)*BW*5,y+(Math.random()-0.5)*BW*5,BW*(1+Math.random()*2),0,Math.PI*2);ctx.fill();}
        }else{ctx.lineWidth=BW;ctx.strokeStyle='rgba(216,90,48,0.85)';ctx.lineCap='round';ctx.beginPath();ctx.moveTo(lx,ly);ctx.lineTo(x,y);ctx.stroke();}
        break;
      case 1:
        ctx.lineWidth=BW;ctx.strokeStyle='rgba(216,90,48,0.85)';ctx.lineCap='round';ctx.beginPath();ctx.moveTo(lx,ly);ctx.lineTo(x,y);ctx.stroke();
        if(inside){var de=Math.min(Math.abs(y-bandTop),Math.abs(y-(bandTop+bandH)));var ne=de<BW*4;var nd=ne?6:2;
          for(var j=0;j<nd;j++){var an=Math.random()*Math.PI*2,di=BW*(1.5+Math.random()*(ne?6:3));
            ctx.fillStyle='rgba(55,138,221,'+(ne?0.06:0.03)+')';ctx.beginPath();ctx.arc(x+Math.cos(an)*di,y+Math.sin(an)*di,BW*(0.5+Math.random()*(ne?1.3:0.5)),0,Math.PI*2);ctx.fill();}
        }
        break;
      case 2:
        if(inside&&Math.random()<0.4)return;
        ctx.lineWidth=BW*(inside?(0.15+Math.random()*0.55):1);ctx.globalAlpha=inside?(0.2+Math.random()*0.35):0.85;
        ctx.strokeStyle='#D85A30';ctx.lineCap='round';ctx.beginPath();ctx.moveTo(lx,ly);ctx.lineTo(x,y);ctx.stroke();ctx.globalAlpha=1;
        break;
      case 3:
        ctx.lineWidth=BW;ctx.strokeStyle='rgba(216,90,48,0.85)';ctx.lineCap='round';ctx.beginPath();ctx.moveTo(lx,ly);ctx.lineTo(x,y);ctx.stroke();
        break;
      case 4:
        if(inside){ctx.globalCompositeOperation='destination-out';ctx.beginPath();ctx.arc(x,y,BW*1.8,0,Math.PI*2);ctx.fillStyle='rgba(0,0,0,0.09)';ctx.fill();ctx.globalCompositeOperation='source-over';}
        break;
    }
  }
  function gp(e){var r=cv.getBoundingClientRect();return{x:e.clientX-r.left,y:e.clientY-r.top};}
  cv.addEventListener('pointerdown',function(e){cv.setPointerCapture(e.pointerId);var p=gp(e);lpx=p.x;lpy=p.y;drawing=true;});
  cv.addEventListener('pointermove',function(e){if(!drawing)return;var p=gp(e);doStamp(p.x,p.y,lpx,lpy);lpx=p.x;lpy=p.y;});
  function stop(){drawing=false;}
  cv.addEventListener('pointerup',stop);cv.addEventListener('pointerleave',stop);cv.addEventListener('pointercancel',stop);
  function sm(m){mode=m;
    [0,1,2,3,4].forEach(function(i){var b=shell.querySelector('#im'+i);b.classList.toggle('active',i===m);});
    shell.querySelector('#iDesc').textContent=DESC[m];drawBand();
  }
  [0,1,2,3,4].forEach(function(i){shell.querySelector('#im'+i).onclick=function(){sm(i);};});
  shell.querySelector('#iReset').onclick=drawBand;
  window.addEventListener('resize',resize);
  resize();sm(0);
  setCleanup(function(){window.removeEventListener('resize',resize);});
}

render();
</script>
